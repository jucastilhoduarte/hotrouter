<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="48dp">

    <!-- Header: somente o logo, centralizado -->
    <ImageView
        android:layout_width="128dp"
        android:layout_height="128dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/ic_wifi"
        android:contentDescription="@string/app_name" />

    <!-- Big toggle button -->
    <LinearLayout
        android:id="@+id/big_button"
        android:layout_width="600dp"
        android:layout_height="190dp"
        android:layout_marginTop="104dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_button"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:id="@+id/state_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/state_off"
            android:textColor="@color/white"
            android:textSize="72sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:id="@+id/state_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/hint_tap_to_on"
            android:textColor="#CCFFFFFF"
            android:textSize="28sp" />
    </LinearLayout>

    <!-- Route chip -->
    <TextView
        android:id="@+id/route_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:background="@drawable/bg_chip"
        android:paddingStart="36dp"
        android:paddingEnd="36dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:text="@string/route_none"
        android:textColor="@color/text_primary"
        android:textSize="30sp" />

    <!-- Botões de ação -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/logs_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_logs_button"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical"
            android:drawableStart="@drawable/ic_logs"
            android:drawablePadding="16dp"
            android:text="@string/logs"
            android:textColor="@color/text_secondary"
            android:textSize="26sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/settings_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_logs_button"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:gravity="center_vertical"
            android:drawableStart="@drawable/ic_settings"
            android:drawablePadding="16dp"
            android:text="@string/settings"
            android:textColor="@color/text_secondary"
            android:textSize="26sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>
</LinearLayout>
